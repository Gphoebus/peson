        </property>
        <property name="styleSheet">
         <string>color: #fab387; font-weight: bold; padding: 4px; border: 1px solid #45475a; border-radius: 4px;</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QLabel" name="label_avg">
        <property name="text">
         <string>Moy: 0.00 N</string>
        </property>
        <property name="alignment">
         <set>Qt::AlignCenter</set>
        </property>
        <property name="styleSheet">
         <string>color: #89b4fa; font-weight: bold; padding: 4px; border: 1px solid #45475a; border-radius: 4px;</string>
